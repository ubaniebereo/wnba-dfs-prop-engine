# Copy this file to `.env` and fill in your keys.  NEVER commit `.env`.
# Loaded by python-dotenv via src/config.py.

# The Odds API — live + historical sportsbook props (incl. Pinnacle anchor).
# https://the-odds-api.com
ODDS_API_KEY=

# BallDontLie WNBA — 2008–2026 box scores + positions.
# https://www.balldontlie.io
BALLDONTLIE_API_KEY=

# X / Twitter API bearer token — beat-writer / injury news monitoring.
# Paste the RAW token exactly as issued (do NOT URL-decode it).
X_BEARER_TOKEN=

# ---- optional overrides ----
# WNBA_SEASONS=2024,2025
# WNBA_LOG_LEVEL=INFO
# WNBA_REQUEST_PAUSE=0.4
